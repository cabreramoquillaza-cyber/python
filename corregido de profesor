        if item["categoria"] == categoria and item["modelo"] == modelo:
            print(f"Error: El modelo '{modelo}' para la categoría '{categoria}' ya está registrado.")
            return
            
    s, m, l = leerStockTallas()
    v_precio = leerPrecio()
    
    
