def modificar():
    print("\n" + "-" * 50)
    print("MODIFICAR PRECIOS O STOCK DE PRENDA")
    print("-" * 50)
    try:
        clave = int(input("Ingrese el código único del producto: "))
    except ValueError:
        print("Error: Debe ingresar un código numérico.")
        return
    
    if clave in inventario:
        item = inventario[clave]
        print(f"\n[Editando] Producto: {item['categoria']} - {item['modelo']}")
        print("--------------------------------------------------")
        
        s, m, l = leerStockTallas()
        v_precio = leerPrecio()
        
        item["S"] = s
        item["M"] = m
        item["L"] = l
        item["precio"] = v_precio
        
        print(f"\n¡Precio y Stock actualizados con éxito para el Código {clave}!")
    else:
        print("Error: Código de producto no localizado.")

def aumentarStock():
    print("\n" + "=" * 50)
    print("INGRESO DE NUEVA MERCADERÍA (AUMENTAR STOCK)")
    print("=" * 50)
    try:
        clave = int(input("Ingrese el código único del producto: "))
    except ValueError:
        print("Error: Código numérico inválido.")
        return
    
    if clave in inventario:
        item = inventario[clave]
        talla = seleccionarTalla()
        try:
            nuevo = int(input(f"Cantidad de unidades a ingresar [{item['categoria']} {item['modelo']} - Talla {talla}]: "))
            if nuevo <= 0:
                print("Error: La cantidad debe ser positiva.")
                return
        except ValueError:
            print("Error: Ingrese solo números.")
            return
        
        item[talla] += nuevo
        print(f"\n¡Stock actualizado! Inventario actual de {item['modelo']} ({talla}): {item[talla]} unidades.")
    else:
        print("Error: El código de producto no está registrado.")

def reducirStock():
    print("\n" + "-" * 50)
    print("REGISTRAR NUEVA VENTA MANUAL (REDUCIR STOCK)")
    print("-" * 50)
    try:
        clave = int(input("Ingrese el código único del producto vendido: "))
    except ValueError:
        print("Error: Código numérico inválido.")
        return
    
    if clave in inventario:
        item = inventario[clave]
        talla = seleccionarTalla()
        try:
            cantidad = int(input(f"Cantidad de unidades vendidas [{item['modelo']} - Talla {talla}]: "))
            if cantidad <= 0:
                print("Error: Ingrese un valor válido.")
                return
        except ValueError:
            print("Error: Ingrese solo números enteros.")
            return
        
        if cantidad <= item[talla]:
            item[talla] -= cantidad 
            print(f"\n¡Venta registrada con éxito! Quedan {item[talla]} unidades disponibles en Talla {talla}.")
        else:
            print(f"\nError: Stock insuficiente. Solo cuentas con {item[talla]} unidades.")
    else:
        print("Error: El código de producto no está registrado.")

